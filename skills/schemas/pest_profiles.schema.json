{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pest_profiles.schema.json",
  "title": "Pest Profiles",
  "description": "Pest vulnerability and treatment profiles per plant.",
  "type": "object",
  "required": ["version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["plantId", "displayName"],
      "additionalProperties": true,
      "properties": {
        "plantId": {
          "type": "string"
        },
        "profileId": {
          "type": ["string", "null"],
          "description": "Stable profile identifier. Defaults to the plantId when omitted."
        },
        "displayName": {
          "type": "string"
        },
        "knownVulnerabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known pest/disease vulnerabilities."
        },
        "preventiveTreatments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recommended preventive treatments."
        },
        "checkFrequencyDays": {
          "type": ["array", "null"],
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2,
          "description": "[min, max] days between pest checks."
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
