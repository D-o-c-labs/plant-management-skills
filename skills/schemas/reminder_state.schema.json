{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reminder_state.schema.json",
  "title": "Reminder State",
  "description": "Runtime state of active and historical reminder tasks. Keys in 'tasks' are task IDs.",
  "type": "object",
  "required": ["version", "tasks", "meta"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "tasks": {
      "type": "object",
      "description": "Map of taskId → task object.",
      "additionalProperties": { "$ref": "#/$defs/task" }
    },
    "meta": {
      "type": "object",
      "description": "Metadata about the reminder state (e.g. last evaluation timestamp).",
      "additionalProperties": true
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["taskId", "type", "status", "createdAt"],
      "additionalProperties": true,
      "properties": {
        "taskId": {
          "type": "string",
          "description": "Stable task identifier, e.g. 'watering_check:plant_001'."
        },
        "type": {
          "type": "string",
          "description": "Task type, e.g. 'watering_check', 'neem', 'fertilization_check'."
        },
        "status": {
          "type": "string",
          "enum": ["open", "done", "expired", "cancelled"],
          "description": "Current status of the task."
        },
        "plantId": {
          "type": ["string", "null"],
          "description": "Target plant ID, if plant-specific."
        },
        "locationId": {
          "type": ["string", "null"],
          "description": "Target location ID."
        },
        "subLocationId": {
          "type": ["string", "null"],
          "description": "Target microzone ID."
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601 timestamp when this task was created."
        },
        "dueAt": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp when this task is/was due."
        },
        "lastReminderAt": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp of the last reminder sent for this task."
        },
        "lastEvaluationAt": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp of the last evaluation that touched this task."
        },
        "lastReason": {
          "type": ["string", "null"],
          "description": "Human-readable reason for the current state."
        },
        "pushCount": {
          "type": "integer",
          "minimum": 0,
          "description": "How many times a reminder has been pushed for this task."
        },
        "confirmationEventId": {
          "type": ["string", "null"],
          "description": "Reference to the event that confirmed/closed this task."
        }
      }
    }
  }
}
