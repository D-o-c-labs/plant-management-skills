{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "care_rules.schema.json",
  "title": "Care Rules",
  "description": "Generic evaluation rules that bind the engine to profile families, history, filters, and output behavior.",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dayInterval": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "minItems": 2,
      "maxItems": 2
    },
    "monthArray": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 12
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statuses": {
          "$ref": "#/$defs/stringArray"
        },
        "plantIds": {
          "$ref": "#/$defs/stringArray"
        },
        "locationIds": {
          "$ref": "#/$defs/stringArray"
        },
        "subLocationIds": {
          "$ref": "#/$defs/stringArray"
        },
        "requiredRiskFlagsAny": {
          "$ref": "#/$defs/stringArray"
        },
        "requiredRiskFlagsAll": {
          "$ref": "#/$defs/stringArray"
        },
        "excludedRiskFlagsAny": {
          "$ref": "#/$defs/stringArray"
        },
        "indoorOutdoor": {
          "type": "string"
        }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventTypes": {
          "$ref": "#/$defs/stringArray"
        },
        "confirmEventType": {
          "type": "string"
        }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seasonalIntervalsField": {
          "type": "string"
        },
        "seasonalIntervalField": {
          "type": "string"
        },
        "intervalFields": {
          "$ref": "#/$defs/stringArray"
        },
        "activeMonthsField": {
          "type": "string"
        },
        "disabledMonthsField": {
          "type": "string"
        },
        "reducedMonthsField": {
          "type": "string"
        },
        "programsField": {
          "type": "string"
        },
        "anchorField": {
          "type": "string"
        },
        "intervalUnit": {
          "type": "string",
          "enum": ["days", "years"]
        },
        "requireExplicitInterval": {
          "type": "boolean"
        },
        "fallbackIntervalDays": {
          "$ref": "#/$defs/dayInterval"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "suggestedAction": {
          "type": "string"
        },
        "recoveringSuggestedAction": {
          "type": "string"
        },
        "recoveringMinimumUrgency": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "defaultConfidence": {
          "type": "string"
        },
        "confidenceWhenWeatherProvided": {
          "type": "string"
        },
        "confidenceWithoutWeather": {
          "type": "string"
        },
        "reducedMonthUrgency": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "noHistoryReason": {
          "type": "string"
        },
        "programNoHistoryReason": {
          "type": "string"
        },
        "windowUrgency": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    },
    "rule": {
      "type": "object",
      "required": ["ruleId", "enabled", "engine", "profileType", "taskType", "history", "schedule"],
      "additionalProperties": false,
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "engine": {
          "type": "string",
          "enum": ["seasonal_profile_interval", "profile_interval", "profile_program_interval", "profile_month_window"]
        },
        "profileType": {
          "type": "string",
          "enum": ["watering", "fertilization", "repotting", "pest", "maintenance", "healthcheck"]
        },
        "taskType": {
          "type": "string"
        },
        "filters": {
          "$ref": "#/$defs/filters"
        },
        "history": {
          "$ref": "#/$defs/history"
        },
        "schedule": {
          "$ref": "#/$defs/schedule"
        },
        "outputs": {
          "$ref": "#/$defs/outputs"
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
